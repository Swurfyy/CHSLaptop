[Unit]
Description=CHS Laptop FastAPI Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/chs-laptop
EnvironmentFile=/opt/chs-laptop/.env
ExecStart=/opt/chs-laptop/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
